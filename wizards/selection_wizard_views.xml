<odoo>
    <record id="view_otm_vendor_selection_wizard_form" model="ir.ui.view">
        <field name="name">otm.vendor.selection.wizard.form</field>
        <field name="model">otm.vendor.selection.wizard</field>
        <field name="arch" type="xml">
            <form string="Select Products">
                <group>
                    <field name="submission_count" string="Products to Select"/>
                    <field name="submission_ids" widget="many2many_tags" readonly="1"/>
                    <field name="selected_qty"/>
                    <field name="negotiated_price"/>
                    <field name="selection_notes" placeholder="Optional selection note visible to the vendor..."/>
                </group>
                <footer>
                    <button name="action_confirm" type="object" string="Confirm Selection"
                            class="btn-success"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_otm_vendor_selection_wizard" model="ir.actions.act_window">
        <field name="name">Select Products</field>
        <field name="res_model">otm.vendor.selection.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_otm_vendor_product_submission"/>
        <field name="binding_view_types">list,kanban</field>
        <field name="group_ids" eval="[(4, ref('otm_vendor_product_selection.group_otm_vendor_manager'))]"/>
    </record>
</odoo>
